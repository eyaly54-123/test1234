</footer>

<!-- LOGIN MODAL -->
<div class="modal-overlay" id="modal" onclick="handleOverlayClick(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>

    <!-- LOGIN SCREEN -->
    <div id="screen-login">
      <div class="modal-title">ברוך הבא 👋</div>
      <div class="modal-sub">כנס לחשבון שלך</div>

      <button class="google-btn" onclick="handleGoogle()">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        המשך עם Google
      </button>

      <div class="divider">או עם אימייל</div>

      <div class="form-group">
        <label class="form-label">אימייל</label>
        <input class="form-input" type="email" placeholder="you@example.com" id="login-email"/>
      </div>
      <div class="form-group">
        <label class="form-label">סיסמה</label>
        <input class="form-input" type="password" placeholder="••••••••" id="login-pass"/>
      </div>
      <button class="submit-btn" onclick="handleLogin()">כניסה</button>

      <div class="modal-switch">
        אין לך חשבון? <a onclick="switchScreen('register')">הירשם עכשיו</a>
      </div>
    </div>

    <!-- REGISTER SCREEN -->
    <div id="screen-register" style="display:none">
      <div class="modal-title">יצירת חשבון 🚀</div>
      <div class="modal-sub">הצטרף לפלטפורמה</div>

      <button class="google-btn" onclick="handleGoogle()">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        המשך עם Google
      </button>

      <div class="divider">או עם אימייל</div>

      <div class="form-group">
        <label class="form-label">שם מלא</label>
        <input class="form-input" type="text" placeholder="השם שלך" id="reg-name"/>
      </div>
      <div class="form-group">
        <label class="form-label">אימייל</label>
        <input class="form-input" type="email" placeholder="you@example.com" id="reg-email"/>
      </div>
      <div class="form-group">
        <label class="form-label">סיסמה</label>
        <input class="form-input" type="password" placeholder="לפחות 8 תווים" id="reg-pass"/>
      </div>
      <button class="submit-btn" onclick="handleRegister()">יצירת חשבון</button>

      <div class="modal-switch">
        כבר יש לך חשבון? <a onclick="switchScreen('login')">כניסה</a>
      </div>
    </div>

    <!-- OTP SCREEN -->
    <div id="screen-otp" style="display:none">
      <div class="modal-title">אימות חשבון 🔐</div>
      <div class="modal-sub" id="otp-sub">שלחנו קוד ל-6 ספרות לאימייל שלך</div>
      <div class="otp-inputs">
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,0)"/>
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,1)"/>
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,2)"/>
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,3)"/>
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,4)"/>
        <input class="otp-input" maxlength="1" type="text" inputmode="numeric" oninput="otpNext(this,5)"/>
      </div>
      <button class="submit-btn" onclick="handleOTP()">אימות</button>
      <div class="otp-resend">לא קיבלת? <a onclick="resendOTP()">שלח שוב</a></div>
    </div>

  </div>
</div>

<script>
  // ─── MODAL ───
  function openModal(screen) {
    switchScreen(screen);
    document.getElementById('modal').classList.add('active');
  }
  function closeModal() {
    document.getElementById('modal').classList.remove('active');
  }
  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modal')) closeModal();
  }
  function switchScreen(name) {
    ['login','register','otp'].forEach(s => {
      document.getElementById('screen-' + s).style.display = (s === name) ? 'block' : 'none';
    });
  }

  // ─── AUTH HANDLERS (stubs — connect Firebase) ───
  function handleGoogle() {
    alert('Google Sign-In — חבר את Firebase Authentication');
  }
  function handleLogin() {
    const email = document.getElementById('login-email').value;
    const pass  = document.getElementById('login-pass').value;
    if (!email || !pass) { alert('אנא מלא את כל השדות'); return; }
    // TODO: firebase signInWithEmailAndPassword(auth, email, pass)
    alert('כניסה בוצעה! (חבר Firebase)');
    closeModal();
  }
  function handleRegister() {
    const name  = document.getElementById('reg-name').value;
    const email = document.getElementById('reg-email').value;
    const pass  = document.getElementById('reg-pass').value;
    if (!name || !email || !pass) { alert('אנא מלא את כל השדות'); return; }
    // TODO: firebase createUserWithEmailAndPassword then sendVerificationEmail
    document.getElementById('otp-sub').textContent = `שלחנו קוד אימות ל-${email}`;
    switchScreen('otp');
  }
  function handleOTP() {
    const inputs = document.querySelectorAll('.otp-input');
    const code = [...inputs].map(i => i.value).join('');
    if (code.length < 6) { alert('אנא הכנס 6 ספרות'); return; }
    // TODO: verify OTP via Firebase
    alert(`קוד ${code} אומת! (חבר Firebase)`);
    closeModal();
  }
  function otpNext(el, idx) {
    if (el.value.length === 1) {
      const inputs = document.querySelectorAll('.otp-input');
      if (idx < 5) inputs[idx + 1].focus();
    }
  }
  function resendOTP() {
    alert('קוד חדש נשלח!');
  }

  // ─── KEYBOARD ESC ───
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
</body>
</html>
